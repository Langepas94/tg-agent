# Required
TELEGRAM_BOT_TOKEN=your_bot_token_here
DIGEST_CHAT_ID=123456789          # Your Telegram user/chat ID

# MCP — pick one:
MCP_HTTP_URL=http://localhost:8080/mcp
# MCP_COMMAND=tracker-mcp-server
# MCP_ARGS=

# LLM (free-text agent + trip-planning swarm). Without a key only commands work.
LLM_API_KEY=your_llm_key_here     # or DEEPSEEK_API_KEY
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat           # base model for every swarm agent
SUPPORT_SERVICE_URL=https://support.5-129-234-9.sslip.io
SUPPORT_ACCESS_KEY=replace-on-server

# Per-agent model overrides for the swarm (optional). Suffix = agent name in
# UPPER_SNAKE. Unset → the agent uses LLM_MODEL. Each swarm agent is its own
# entity and may run a different model.
# SWARM_MODEL_BRIEFAGENT=cheap-fast-model
# SWARM_MODEL_VERIFIERAGENT=strict-reasoning-model
# SWARM_MODEL_ARTIFACTSAGENT=reliable-writer-model

# Optional
DIGEST_INTERVAL_MINUTES=360       # How often to send digest (default 6h)
RUST_LOG=tg_agent=info,rmcp=info
