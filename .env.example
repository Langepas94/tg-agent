# Required
TELEGRAM_BOT_TOKEN=your_bot_token_here
DIGEST_CHAT_ID=123456789          # Your Telegram user/chat ID

# MCP — pick one:
MCP_HTTP_URL=http://localhost:8080/mcp
# MCP_COMMAND=tracker-mcp-server
# MCP_ARGS=

# LLM (free-text agent + trip-planning swarm). Without a key only commands work.
LLM_API_KEY=your_llm_key_here     # or DEEPSEEK_API_KEY
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat           # base model for every swarm agent

# Per-agent model overrides for the swarm (optional). Suffix = agent name in
# UPPER_SNAKE. Unset → the agent uses LLM_MODEL. Each swarm agent is its own
# entity and may run a different model.
# SWARM_MODEL_BRIEFAGENT=cheap-fast-model
# SWARM_MODEL_VERIFIERAGENT=strict-reasoning-model
# SWARM_MODEL_ARTIFACTSAGENT=reliable-writer-model

# RAG mode (/rag on): answers ordinary questions from a local document index
# built by ollama-rag-indexer, with dialog history, task state, mandatory
# sources + quotes and a "не знаю" refusal below the relevance floor.
# RAG_INDEX=/path/to/indexes-real-qwen/structural
# RAG_INDEXER_BIN=rag-indexer      # or /path/to/.venv/bin/rag-indexer
# RAG_EMBED_MODEL=qwen3-embedding
# RAG_CHAT_MODEL=qwen2.5:7b        # or deepseek-chat with provider=openai
# RAG_CHAT_URL=http://localhost:11434
# RAG_CHAT_PROVIDER=ollama         # openai = OpenAI-compatible API (DeepSeek): embeddings
#                                  # stay local, chat runs on the API — how RAG works on the 2GB VPS
# RAG_CHAT_API_KEY=                # key for provider=openai (rag-indexer reads it from env)
# RAG_OLLAMA_URL=http://localhost:11434
# RAG_SEARCH_MODE=hybrid           # dense | hybrid
# RAG_TOP_K=5
# RAG_REWRITE=1                    # history-aware query rewrite before retrieval
# RAG_MIN_SCORE=0.5                # dense-cosine relevance floor; unset = indexer default 0.35.
#                                  # 0.5 is calibrated for the real tg-agent+open-meteo corpus.

# Optional
DIGEST_INTERVAL_MINUTES=360       # How often to send digest (default 6h)
RUST_LOG=tg_agent=info,rmcp=info
